            if _bl_curl_source "$monolith_key" "$monolith_url" "$verbose" 1; then
                monolith_sourced=1
            else
                [[ "$verbose" -eq 1 ]] && echo -e "\033[1;33m[WARN]\033[0m Monolith failed for '$cat', falling back to individual files." >&2
