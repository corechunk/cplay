            echo -e "\033[1;31m[ERROR]\033[0m '$search_file' is not a .sh or .bash file." >&2
            return $strict
        fi
        if ! _bl_curl_source "$key" "$url" "$verbose" 0; then
            echo -e "\033[1;31m[ERROR]\033[0m Failed to source remote library: $key ($url)" >&2
            return $strict
