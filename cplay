bl_hex_to_rgb() {
    local hex="${1#\#}"
    local r g b
    if [[ ${#hex} -eq 6 ]]; then
        r=$((16#${hex:0:2}))
        g=$((16#${hex:2:2}))
        b=$((16#${hex:4:2}))
    else
        r=0; g=0; b=0
    fi
    echo "$r $g $b"
}

