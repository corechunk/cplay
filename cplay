        elif [[ -f "$item" ]]; then
            type="file"
        fi
        CPLAY_STATS_META["$item"]="$indent|$type|${item##*/}|$parent"
        CPLAY_STATS_ITEMS+=("$item")
        if [[ "$type" == "directory" && "${CPLAY_STATS_EXPANDED["$item"]}" == "true" ]]; then
            tui_collect_subdir_items "$item" $((indent + 1))
        fi
