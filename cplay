}
bl_import_local() {
    bl_check_deps "bl_import_local" || return 1
    local verbose=0
    local strict=0
    local patterns=()
    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            -v|--verbose) verbose=1; shift ;;
            --strict) strict=1; shift ;;
            *) patterns+=("$1"); shift ;;
        esac
    done
    if [[ "${#patterns[@]}" -eq 0 ]]; then
        echo -e "\033[1;31m[import]\033[0m pattern required (e.g. \"lib/*\")" >&2
        return 1
    fi
